import streamlit as st


books = pickle.load(open("books.pkl", "rb"))

selected_book = st.selectbox(
    "Select a Book",
    books["Book-Title"].unique()
)

if st.button("Recommend"):
    recs = recommend(selected_book)

    for book in recs:
        st.write(book["Title"])
        st.write(book["Author"])
        st.write("---")


